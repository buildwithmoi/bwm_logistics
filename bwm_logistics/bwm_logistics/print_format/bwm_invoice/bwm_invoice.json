{
 "creation": "2026-07-11 12:00:00.000000",
 "custom_format": 1,
 "default_print_language": "en",
 "disabled": 0,
 "doc_type": "Sales Invoice",
 "doctype": "Print Format",
 "font_size": 13,
 "html": "{%- set settings = frappe.get_doc('Logistics Settings') -%}\n{%- set business = settings.business_name or 'BWM Logistics' -%}\n{%- set gold = '#b8860b' -%}\n{%- set black = '#0f0f10' -%}\n<div style='font-family: Helvetica, Arial, sans-serif; color: #17150f; font-size: 13px; -webkit-print-color-adjust: exact;'>\n\n\t<!-- Header band -->\n\t<table style='width:100%; border-collapse:collapse; background-color:{{ black }}; color:#ffffff;'>\n\t\t<tr>\n\t\t\t<td style='padding:18px 22px; vertical-align:middle;'>\n\t\t\t\t<div style='font-size:20px; font-weight:bold; letter-spacing:-0.5px;'>{{ business }}</div>\n\t\t\t\t{%- if settings.contact_phone or settings.contact_email %}\n\t\t\t\t<div style='font-size:10px; color:#cccccc; margin-top:3px;'>{{ [settings.contact_phone, settings.contact_email] | select | join(' &middot; ') }}</div>\n\t\t\t\t{%- endif %}\n\t\t\t</td>\n\t\t\t<td style='padding:18px 22px; text-align:right; vertical-align:middle;'>\n\t\t\t\t<div style='font-size:11px; letter-spacing:3px; color:{{ gold }}; font-weight:bold;'>INVOICE</div>\n\t\t\t\t<div style='font-size:15px; font-weight:bold; margin-top:2px;'>{{ doc.name }}</div>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr><td colspan='2' style='height:4px; background-color:{{ gold }}; font-size:1px; line-height:1px;'>&nbsp;</td></tr>\n\t</table>\n\n\t<!-- Meta -->\n\t<table style='width:100%; border-collapse:collapse; margin-top:18px;'>\n\t\t<tr>\n\t\t\t<td style='vertical-align:top; width:55%;'>\n\t\t\t\t<div style='font-size:9px; letter-spacing:2px; color:#888888; font-weight:bold;'>BILLED TO</div>\n\t\t\t\t<div style='font-size:14px; font-weight:bold; margin-top:3px;'>{{ doc.customer_name or doc.customer }}</div>\n\t\t\t\t{%- if doc.bwm_shipment %}\n\t\t\t\t<div style='font-size:11px; color:#666666; margin-top:3px;'>Shipment: <b>{{ doc.bwm_shipment }}</b></div>\n\t\t\t\t{%- endif %}\n\t\t\t</td>\n\t\t\t<td style='vertical-align:top; text-align:right;'>\n\t\t\t\t<table style='border-collapse:collapse; float:right; font-size:11px;'>\n\t\t\t\t\t<tr><td style='padding:2px 10px 2px 0; color:#888888;'>Invoice date</td><td style='padding:2px 0; text-align:right;'>{{ frappe.utils.formatdate(doc.posting_date) }}</td></tr>\n\t\t\t\t\t{%- if doc.due_date %}<tr><td style='padding:2px 10px 2px 0; color:#888888;'>Due date</td><td style='padding:2px 0; text-align:right;'>{{ frappe.utils.formatdate(doc.due_date) }}</td></tr>{%- endif %}\n\t\t\t\t\t<tr><td style='padding:2px 10px 2px 0; color:#888888;'>Status</td><td style='padding:2px 0; text-align:right; font-weight:bold; {% if doc.outstanding_amount <= 0 %}color:#1a7f4e;{% else %}color:#b45309;{% endif %}'>{% if doc.outstanding_amount <= 0 %}PAID{% else %}{{ doc.status | upper }}{% endif %}</td></tr>\n\t\t\t\t</table>\n\t\t\t</td>\n\t\t</tr>\n\t</table>\n\n\t<!-- Items -->\n\t<table style='width:100%; border-collapse:collapse; margin-top:20px;'>\n\t\t<tr>\n\t\t\t<td style='padding:7px 8px; font-size:9px; letter-spacing:2px; color:#888888; font-weight:bold; border-bottom:2px solid {{ black }};'>#</td>\n\t\t\t<td style='padding:7px 8px; font-size:9px; letter-spacing:2px; color:#888888; font-weight:bold; border-bottom:2px solid {{ black }};'>DESCRIPTION</td>\n\t\t\t<td style='padding:7px 8px; font-size:9px; letter-spacing:2px; color:#888888; font-weight:bold; border-bottom:2px solid {{ black }}; text-align:right;'>QTY</td>\n\t\t\t<td style='padding:7px 8px; font-size:9px; letter-spacing:2px; color:#888888; font-weight:bold; border-bottom:2px solid {{ black }}; text-align:right;'>RATE</td>\n\t\t\t<td style='padding:7px 8px; font-size:9px; letter-spacing:2px; color:#888888; font-weight:bold; border-bottom:2px solid {{ black }}; text-align:right;'>AMOUNT</td>\n\t\t</tr>\n\t\t{%- for row in doc.items %}\n\t\t<tr>\n\t\t\t<td style='padding:8px; border-bottom:1px solid #e7e1d5; color:#888888; width:24px;'>{{ loop.index }}</td>\n\t\t\t<td style='padding:8px; border-bottom:1px solid #e7e1d5;'>{{ row.item_name }}{% if row.description and row.description != row.item_name %}<div style='font-size:10px; color:#888888;'>{{ row.description }}</div>{% endif %}</td>\n\t\t\t<td style='padding:8px; border-bottom:1px solid #e7e1d5; text-align:right;'>{{ frappe.utils.flt(row.qty) }}</td>\n\t\t\t<td style='padding:8px; border-bottom:1px solid #e7e1d5; text-align:right;'>{{ row.get_formatted('rate', doc) }}</td>\n\t\t\t<td style='padding:8px; border-bottom:1px solid #e7e1d5; text-align:right;'>{{ row.get_formatted('amount', doc) }}</td>\n\t\t</tr>\n\t\t{%- endfor %}\n\t</table>\n\n\t<!-- Totals -->\n\t<table style='width:100%; border-collapse:collapse; margin-top:12px;'>\n\t\t<tr>\n\t\t\t<td style='width:55%; vertical-align:top; font-size:10px; color:#888888; padding-top:8px;'>\n\t\t\t\t{%- if doc.in_words %}<i>{{ doc.in_words }}</i>{%- endif %}\n\t\t\t</td>\n\t\t\t<td>\n\t\t\t\t<table style='border-collapse:collapse; width:100%; font-size:12px;'>\n\t\t\t\t\t<tr><td style='padding:4px 10px 4px 0; color:#888888;'>Subtotal</td><td style='padding:4px 0; text-align:right;'>{{ doc.get_formatted('net_total') }}</td></tr>\n\t\t\t\t\t{%- if doc.taxes %}{%- for tax in doc.taxes %}{%- if tax.tax_amount %}\n\t\t\t\t\t<tr><td style='padding:4px 10px 4px 0; color:#888888;'>{{ tax.description }}</td><td style='padding:4px 0; text-align:right;'>{{ tax.get_formatted('tax_amount', doc) }}</td></tr>\n\t\t\t\t\t{%- endif %}{%- endfor %}{%- endif %}\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td style='padding:8px 10px 8px 0; font-weight:bold; font-size:14px; border-top:2px solid {{ black }};'>Total</td>\n\t\t\t\t\t\t<td style='padding:8px 0; text-align:right; font-weight:bold; font-size:14px; border-top:2px solid {{ black }};'>{{ doc.get_formatted('rounded_total') if doc.rounded_total else doc.get_formatted('grand_total') }}</td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t{%- if doc.outstanding_amount > 0 and doc.outstanding_amount != doc.grand_total %}\n\t\t\t\t\t<tr><td style='padding:4px 10px 4px 0; color:#888888;'>Paid</td><td style='padding:4px 0; text-align:right;'>{{ frappe.utils.fmt_money(doc.grand_total - doc.outstanding_amount, currency=doc.currency) }}</td></tr>\n\t\t\t\t\t{%- endif %}\n\t\t\t\t\t{%- if doc.outstanding_amount > 0 %}\n\t\t\t\t\t<tr><td style='padding:4px 10px 4px 0; font-weight:bold; color:#b45309;'>Balance due</td><td style='padding:4px 0; text-align:right; font-weight:bold; color:#b45309;'>{{ doc.get_formatted('outstanding_amount') }}</td></tr>\n\t\t\t\t\t{%- endif %}\n\t\t\t\t</table>\n\t\t\t</td>\n\t\t</tr>\n\t</table>\n\n\t<!-- Footer -->\n\t<table style='width:100%; border-collapse:collapse; margin-top:30px;'>\n\t\t<tr><td style='height:2px; background-color:{{ gold }}; font-size:1px; line-height:1px;'>&nbsp;</td></tr>\n\t\t<tr><td style='padding-top:8px; font-size:10px; color:#888888; text-align:center;'>Thank you for your business &mdash; {{ business }}{% if settings.office_hours %} &middot; {{ settings.office_hours }}{% endif %}</td></tr>\n\t</table>\n</div>",
